---
import Base from "../../layouts/Base.astro";

const API_BASE = "/_emdash/api/plugins/commerce";

// Fetch products server-side
const res = await fetch(new URL(`${API_BASE}/products/list`, Astro.url), {
	headers: { "Content-Type": "application/json" },
});
const body = await res.json();
const products = body?.data?.items ?? [];
---

<Base title="Shop">
	<main class="shop-page">
		<h1>Shop</h1>

		{products.length === 0 ? (
			<p class="shop-empty">No products available yet. Check back soon!</p>
		) : (
			<div class="product-grid">
				{products.map((product: Record<string, unknown>) => (
					<a href={`/shop/${product.slug}`} class="product-card">
						{(product.images as Array<{url: string; alt: string}>)?.length > 0 ? (
							<img
								src={(product.images as Array<{url: string}>)[0]!.url}
								alt={(product.images as Array<{alt: string}>)[0]!.alt || (product.name as string)}
								class="product-card-image"
							/>
						) : (
							<div class="product-card-image product-card-placeholder">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
								</svg>
							</div>
						)}
						<div class="product-card-body">
							<h2 class="product-card-title">{product.name}</h2>
							{product.shortDescription && (
								<p class="product-card-desc">{product.shortDescription}</p>
							)}
							<div class="product-card-price">
								{product.compareAtPrice ? (
									<>
										<span class="price-compare">${(product.compareAtPrice as number).toFixed(2)}</span>
										<span class="price-current">${(product.basePrice as number).toFixed(2)}</span>
									</>
								) : (
									<span class="price-current">${(product.basePrice as number).toFixed(2)}</span>
								)}
							</div>
							{product.status === "active" && (
								<span class="product-badge">In Stock</span>
							)}
						</div>
					</a>
				))}
			</div>
		)}
	</main>
</Base>

<style>
	.shop-page {
		max-width: var(--wide-width, 1200px);
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.shop-page h1 {
		font-size: var(--font-size-3xl, 2rem);
		margin-bottom: 2rem;
	}

	.shop-empty {
		text-align: center;
		padding: 4rem 0;
		color: var(--color-muted, #888);
	}

	.product-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.product-card {
		border: 1px solid var(--color-border, #e5e5e5);
		border-radius: var(--radius-lg, 8px);
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		transition: box-shadow 0.2s, transform 0.2s;
		background: var(--color-bg, #fff);
	}

	.product-card:hover {
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
		transform: translateY(-2px);
	}

	.product-card-image {
		width: 100%;
		aspect-ratio: 4/3;
		object-fit: cover;
		background: var(--color-surface, #f7f7f7);
	}

	.product-card-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-muted, #ccc);
	}

	.product-card-placeholder svg {
		width: 48px;
		height: 48px;
	}

	.product-card-body {
		padding: 1rem;
	}

	.product-card-title {
		font-size: var(--font-size-lg, 1.125rem);
		font-weight: 600;
		margin: 0 0 0.25rem;
	}

	.product-card-desc {
		font-size: var(--font-size-sm, 0.875rem);
		color: var(--color-text-secondary, #666);
		margin: 0 0 0.75rem;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.product-card-price {
		font-size: var(--font-size-xl, 1.25rem);
		font-weight: 700;
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.price-compare {
		text-decoration: line-through;
		color: var(--color-muted, #999);
		font-size: var(--font-size-sm, 0.875rem);
		font-weight: 400;
	}

	.price-current {
		color: var(--color-text, #1a1a1a);
	}

	.product-badge {
		display: inline-block;
		margin-top: 0.5rem;
		font-size: 0.75rem;
		font-weight: 600;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
		background: #ecfdf5;
		color: #059669;
	}

	@media (max-width: 640px) {
		.product-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 0.75rem;
		}
	}
</style>
