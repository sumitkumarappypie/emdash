---
import Base from "../../layouts/Base.astro";

const { slug } = Astro.params;
const API_BASE = "/_emdash/api/plugins/commerce";

// Fetch product by slug
const res = await fetch(new URL(`${API_BASE}/products/get`, Astro.url), {
	method: "POST",
	headers: { "Content-Type": "application/json" },
	body: JSON.stringify({ slug }),
});
const body = await res.json();
const product = body?.data;

if (!product) {
	return Astro.redirect("/shop");
}

const variants = product.variants ?? [];
---

<Base title={product.name}>
	<main class="product-page">
		<nav class="breadcrumb">
			<a href="/shop">Shop</a>
			<span>/</span>
			<span>{product.name}</span>
		</nav>

		<div class="product-layout">
			<div class="product-images">
				{product.images?.length > 0 ? (
					<img
						src={product.images[0].url}
						alt={product.images[0].alt || product.name}
						class="product-main-image"
					/>
				) : (
					<div class="product-main-image product-placeholder">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
							<path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
						</svg>
					</div>
				)}
			</div>

			<div class="product-info">
				<h1 class="product-title">{product.name}</h1>

				<div class="product-price">
					{product.compareAtPrice ? (
						<>
							<span class="price-compare">${product.compareAtPrice.toFixed(2)}</span>
							<span class="price-current">${product.basePrice.toFixed(2)}</span>
						</>
					) : (
						<span class="price-current">${product.basePrice.toFixed(2)}</span>
					)}
				</div>

				{product.shortDescription && (
					<p class="product-short-desc">{product.shortDescription}</p>
				)}

				{product.sku && (
					<p class="product-meta">SKU: {product.sku}</p>
				)}

				{variants.length > 0 && (
					<div class="product-variants">
						<label for="variant-select">Options:</label>
						<select id="variant-select" class="variant-select">
							{variants.map((v: Record<string, unknown>) => (
								<option value={v.id as string}>
									{v.name}{v.price !== null ? ` — $${(v.price as number).toFixed(2)}` : ""}
								</option>
							))}
						</select>
					</div>
				)}

				<div class="product-actions">
					<div class="quantity-input">
						<label for="quantity">Qty:</label>
						<input type="number" id="quantity" value="1" min="1" max="99" />
					</div>
					<button
						class="add-to-cart-btn"
						data-product-id={product.id}
						data-price={product.basePrice}
					>
						Add to Cart
					</button>
				</div>

				{product.trackInventory && (
					<p class="stock-info">
						{product.inventoryQuantity > 0
							? `${product.inventoryQuantity} in stock`
							: "Out of stock"}
					</p>
				)}

				{product.description && (
					<div class="product-description">
						<h2>Description</h2>
						<p>{product.description}</p>
					</div>
				)}
			</div>
		</div>
	</main>
</Base>

<style>
	.product-page {
		max-width: var(--wide-width, 1200px);
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.breadcrumb {
		font-size: var(--font-size-sm, 0.875rem);
		color: var(--color-muted, #888);
		margin-bottom: 1.5rem;
		display: flex;
		gap: 0.5rem;
	}

	.breadcrumb a {
		color: var(--color-accent, #0066cc);
		text-decoration: none;
	}

	.product-layout {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
	}

	.product-main-image {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--radius-lg, 8px);
		background: var(--color-surface, #f7f7f7);
	}

	.product-placeholder {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-muted, #ccc);
	}

	.product-placeholder svg {
		width: 80px;
		height: 80px;
	}

	.product-title {
		font-size: var(--font-size-3xl, 2rem);
		margin: 0 0 0.75rem;
	}

	.product-price {
		font-size: var(--font-size-2xl, 1.5rem);
		font-weight: 700;
		margin-bottom: 1rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.price-compare {
		text-decoration: line-through;
		color: var(--color-muted, #999);
		font-size: var(--font-size-lg, 1.125rem);
		font-weight: 400;
	}

	.product-short-desc {
		color: var(--color-text-secondary, #525252);
		margin-bottom: 1rem;
		line-height: var(--leading-relaxed, 1.7);
	}

	.product-meta {
		font-size: var(--font-size-sm, 0.875rem);
		color: var(--color-muted, #888);
		margin-bottom: 1.5rem;
	}

	.product-variants {
		margin-bottom: 1.5rem;
	}

	.product-variants label {
		display: block;
		font-weight: 600;
		margin-bottom: 0.5rem;
	}

	.variant-select {
		width: 100%;
		padding: 0.5rem;
		border: 1px solid var(--color-border, #e5e5e5);
		border-radius: var(--radius, 4px);
		font: inherit;
	}

	.product-actions {
		display: flex;
		gap: 1rem;
		align-items: flex-end;
		margin-bottom: 1rem;
	}

	.quantity-input label {
		display: block;
		font-size: var(--font-size-sm, 0.875rem);
		font-weight: 600;
		margin-bottom: 0.25rem;
	}

	.quantity-input input {
		width: 70px;
		padding: 0.6rem 0.5rem;
		border: 1px solid var(--color-border, #e5e5e5);
		border-radius: var(--radius, 4px);
		font: inherit;
		text-align: center;
	}

	.add-to-cart-btn {
		flex: 1;
		padding: 0.7rem 2rem;
		font: inherit;
		font-weight: 600;
		background: var(--color-accent, #0066cc);
		color: white;
		border: none;
		border-radius: var(--radius, 4px);
		cursor: pointer;
		transition: background 0.2s;
	}

	.add-to-cart-btn:hover {
		background: var(--color-accent-hover, #0052a3);
	}

	.stock-info {
		font-size: var(--font-size-sm, 0.875rem);
		color: #059669;
		font-weight: 500;
	}

	.product-description {
		margin-top: 2rem;
		padding-top: 2rem;
		border-top: 1px solid var(--color-border, #e5e5e5);
	}

	.product-description h2 {
		font-size: var(--font-size-xl, 1.25rem);
		margin-bottom: 0.75rem;
	}

	.product-description p {
		line-height: var(--leading-relaxed, 1.7);
		color: var(--color-text-secondary, #525252);
	}

	@media (max-width: 768px) {
		.product-layout {
			grid-template-columns: 1fr;
			gap: 1.5rem;
		}
	}
</style>
