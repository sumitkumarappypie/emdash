{
	"expo": {
		"name": "EmDash",
		"slug": "emdash-mobile",
		"version": "0.1.0",
		"scheme": "emdash",
		"orientation": "portrait",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.emdash.mobile"
		},
		"android": {
			"adaptiveIcon": {
				"backgroundColor": "#ffffff"
			},
			"package": "com.emdash.mobile"
		},
		"plugins": ["expo-router", "expo-secure-store"],
		"experiments": {
			"typedRoutes": true
		}
	}
}
