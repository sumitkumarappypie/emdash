---
// @ts-ignore virtual module
import { Layout } from "virtual:commerce-storefront/config";

export const prerender = false;

const emdash = (Astro.locals as any).emdash;
if (!emdash?.handlePluginApiRoute) return Astro.redirect("/404");

const statusResult = await emdash.handlePluginApiRoute(
	"commerce", "POST", "/storefront/status",
	new Request("https://internal/status", { method: "POST", body: "{}" }),
);
if (!statusResult?.success || !statusResult.data?.enabled) return Astro.redirect("/404");
---

<Layout title="Log In">
	<main class="auth-page">
		<div class="auth-card">
			<h1>Log In</h1>
			<form id="login-form">
				<div class="form-field">
					<label for="l-email">Email</label>
					<input type="email" id="l-email" name="email" required autocomplete="email" />
				</div>
				<div class="form-field">
					<label for="l-password">Password</label>
					<input type="password" id="l-password" name="password" required autocomplete="current-password" />
				</div>
				<p id="login-error" class="auth-error" style="display:none"></p>
				<button type="submit" class="auth-btn">Log In</button>
			</form>
			<p class="auth-link">Don't have an account? <a href="/shop/register">Create one</a></p>
		</div>
	</main>
</Layout>

<script>
	const API_BASE = "/_emdash/api/plugins/commerce";

	// Redirect if already logged in
	const existingToken = localStorage.getItem("commerce_customer_token");
	if (existingToken) {
		window.location.href = "/shop/account";
	}

	const errorEl = document.getElementById("login-error")!;

	document.getElementById("login-form")?.addEventListener("submit", async (e) => {
		e.preventDefault();
		errorEl.style.display = "none";
		const btn = (e.currentTarget as HTMLFormElement).querySelector("button[type=submit]") as HTMLButtonElement;
		btn.disabled = true;
		btn.textContent = "Logging in...";

		const email = (document.getElementById("l-email") as HTMLInputElement).value;
		const password = (document.getElementById("l-password") as HTMLInputElement).value;

		try {
			const res = await fetch(`${API_BASE}/customer/login`, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({ email, password }),
			});
			const body = await res.json();
			if (body?.data?.token) {
				localStorage.setItem("commerce_customer_token", body.data.token);
				const params = new URLSearchParams(window.location.search);
				const returnUrl = params.get("returnUrl");
				window.location.href = returnUrl && returnUrl.startsWith("/") && !returnUrl.startsWith("//")
					? returnUrl
					: "/shop";
			} else {
				const msg = body?.error?.message || body?.data?.message || "Invalid email or password.";
				errorEl.textContent = msg;
				errorEl.style.display = "block";
				btn.disabled = false;
				btn.textContent = "Log In";
			}
		} catch {
			errorEl.textContent = "Network error. Please try again.";
			errorEl.style.display = "block";
			btn.disabled = false;
			btn.textContent = "Log In";
		}
	});
</script>

<style is:global>
	.auth-page {
		display: flex;
		justify-content: center;
		align-items: flex-start;
		padding: 3rem var(--spacing-6, 1.5rem) 4rem;
		min-height: 60vh;
	}

	.auth-card {
		width: 100%;
		max-width: 420px;
		border: 1px solid var(--color-border, #e5e5e5);
		border-radius: 12px;
		padding: 2.5rem 2rem;
		background: var(--color-bg, #fff);
	}

	.auth-page h1 {
		text-align: center;
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: 1.75rem;
		letter-spacing: -0.02em;
		color: var(--color-text, #1a1a1a);
	}

	.auth-btn {
		width: 100%;
		padding: 0.875rem;
		font: inherit;
		font-size: 1rem;
		font-weight: 600;
		background: var(--color-accent, #0066cc);
		color: white;
		border: none;
		border-radius: 8px;
		cursor: pointer;
		margin-top: 0.5rem;
		transition: background 0.2s, transform 0.1s;
	}

	.auth-btn:hover { background: var(--color-accent-hover, #0052a3); }
	.auth-btn:active { transform: scale(0.98); }
	.auth-btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

	.auth-error {
		color: #dc2626;
		font-size: 0.875rem;
		margin-top: 0.75rem;
		margin-bottom: 0.5rem;
		padding: 0.5rem 0.75rem;
		background: #fef2f2;
		border-radius: 6px;
		border: 1px solid #fecaca;
	}

	.auth-link {
		text-align: center;
		margin-top: 1.25rem;
		font-size: 0.875rem;
		color: var(--color-muted, #888);
	}

	.auth-link a {
		color: var(--color-accent, #0066cc);
		text-decoration: none;
	}

	.auth-link a:hover { text-decoration: underline; }
</style>
