---
// @ts-ignore virtual module
import { Layout } from "virtual:commerce-storefront/config";

export const prerender = false;

const emdash = (Astro.locals as any).emdash;
if (!emdash?.handlePluginApiRoute) return Astro.redirect("/404");

// Direct runtime call — no self-fetch, works on both Node and Workers
const statusResult = await emdash.handlePluginApiRoute(
	"commerce", "POST", "/storefront/status",
	new Request("https://internal/status", { method: "POST", body: "{}" }),
);
if (!statusResult?.success || !statusResult.data?.enabled) return Astro.redirect("/404");

const productsResult = await emdash.handlePluginApiRoute(
	"commerce", "POST", "/products/list",
	new Request("https://internal/products", {
		method: "POST",
		headers: { "Content-Type": "application/json" },
		body: JSON.stringify({ status: "active" }),
	}),
);
const rawProducts = productsResult?.data?.items ?? [];

const products = rawProducts.map((p: any) => ({
	slug: p.slug ?? "",
	name: p.name ?? "",
	shortDescription: p.shortDescription ?? "",
	basePrice: Number(p.basePrice ?? 0),
	compareAtPrice: p.compareAtPrice ? Number(p.compareAtPrice) : null,
	status: p.status ?? "draft",
	images: Array.isArray(p.images) ? p.images : [],
}));
---

<Layout title="Shop">
	<main class="shop-page">
		<h1>Shop</h1>

		{products.length === 0 ? (
			<p class="shop-empty">No products available yet. Check back soon!</p>
		) : (
			<div class="product-grid">
				{products.map((product) => (
					<a href={`/shop/${product.slug}`} class="product-card">
						{product.images.length > 0 ? (
							<img
								src={product.images[0].url}
								alt={product.images[0].alt || product.name}
								class="product-card-image"
							/>
						) : (
							<div class="product-card-image product-card-placeholder">
								<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
									<path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
								</svg>
							</div>
						)}
						<div class="product-card-body">
							<h2 class="product-card-title">{product.name}</h2>
							{product.shortDescription && (
								<p class="product-card-desc">{product.shortDescription}</p>
							)}
							<div class="product-card-price">
								{product.compareAtPrice ? (
									<>
										<span class="price-compare">${product.compareAtPrice.toFixed(2)}</span>
										<span class="price-current">${product.basePrice.toFixed(2)}</span>
									</>
								) : (
									<span class="price-current">${product.basePrice.toFixed(2)}</span>
								)}
							</div>
							{product.status === "active" && (
								<span class="product-badge">In Stock</span>
							)}
						</div>
					</a>
				))}
			</div>
		)}
	</main>
</Layout>

<style is:global>
	.shop-page { max-width: var(--wide-width, 1200px); margin: 0 auto; padding: 2rem var(--spacing-6, 1.5rem) 4rem; }
	.shop-page h1 { font-size: 2rem; font-weight: 700; margin-bottom: 2rem; letter-spacing: -0.02em; }
	.shop-empty { text-align: center; padding: 4rem 0; color: var(--color-muted, #888); }
	.product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem; }
	.product-card { border: 1px solid var(--color-border, #e5e5e5); border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; transition: box-shadow 0.25s ease, transform 0.25s ease; background: var(--color-bg, #fff); }
	.product-card:hover { box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08); transform: translateY(-4px); }
	.product-card-image { width: 100%; aspect-ratio: 4/3; object-fit: cover; background: var(--color-surface, #f7f7f7); border-bottom: 1px solid var(--color-border, #e5e5e5); }
	.product-card-placeholder { display: flex; align-items: center; justify-content: center; color: var(--color-border, #ddd); }
	.product-card-placeholder svg { width: 48px; height: 48px; }
	.product-card-body { padding: 1.125rem; }
	.product-card-title { font-size: 1.05rem; font-weight: 600; margin: 0 0 0.25rem; letter-spacing: -0.01em; }
	.product-card-desc { font-size: 0.8125rem; color: var(--color-text-secondary, #666); margin: 0 0 0.75rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }
	.product-card-price { font-size: 1.25rem; font-weight: 700; display: flex; align-items: baseline; gap: 0.5rem; }
	.price-compare { text-decoration: line-through; color: var(--color-muted, #999); font-size: 0.875rem; font-weight: 400; }
	.price-current { color: var(--color-text, #1a1a1a); }
	.product-badge { display: inline-flex; align-items: center; gap: 0.25rem; margin-top: 0.625rem; font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.625rem; border-radius: 100px; background: #ecfdf5; color: #059669; }
	.product-badge::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: #059669; }
	@media (max-width: 640px) { .product-grid { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; } .product-card-body { padding: 0.75rem; } .product-card-title { font-size: 0.9375rem; } .product-card-price { font-size: 1.05rem; } }
</style>
