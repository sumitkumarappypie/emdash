---
interface Props {
	apiBase?: string;
}

const { apiBase = "/_emdash/api/plugins/commerce" } = Astro.props;
---

<div data-commerce-customer-account data-api-base={apiBase}>
	<nav class="commerce-account-nav" aria-label="Account sections">
		<button
			type="button"
			data-commerce-tab="orders"
			class="commerce-account-tab commerce-account-tab--active"
			aria-selected="true"
		>
			Orders
		</button>
		<button
			type="button"
			data-commerce-tab="addresses"
			class="commerce-account-tab"
			aria-selected="false"
		>
			Addresses
		</button>
		<button
			type="button"
			data-commerce-tab="subscriptions"
			class="commerce-account-tab"
			aria-selected="false"
		>
			Subscriptions
		</button>
	</nav>

	<!-- Order History -->
	<section data-commerce-panel="orders" class="commerce-account-panel">
		<h2 class="commerce-section-title">Order History</h2>
		<p data-commerce-orders-empty class="commerce-empty-state" hidden>
			You haven't placed any orders yet.
		</p>
		<div data-commerce-orders-list class="commerce-orders-list">
			<p data-commerce-loading class="commerce-loading-state">Loading orders...</p>
		</div>
	</section>

	<!-- Address Book -->
	<section data-commerce-panel="addresses" class="commerce-account-panel" hidden>
		<div class="commerce-section-header">
			<h2 class="commerce-section-title">Address Book</h2>
			<button type="button" data-commerce-btn="primary" data-commerce-add-address>
				Add Address
			</button>
		</div>
		<p data-commerce-addresses-empty class="commerce-empty-state" hidden>
			No saved addresses.
		</p>
		<div data-commerce-addresses-list class="commerce-addresses-list"></div>

		<form data-commerce-address-form class="commerce-address-form" hidden novalidate>
			<h3 class="commerce-form-title">New Address</h3>

			<div class="commerce-form-row commerce-form-row--two">
				<div class="commerce-form-field">
					<label for="account-first-name">First Name</label>
					<input id="account-first-name" type="text" name="firstName" autocomplete="given-name" required />
				</div>
				<div class="commerce-form-field">
					<label for="account-last-name">Last Name</label>
					<input id="account-last-name" type="text" name="lastName" autocomplete="family-name" required />
				</div>
			</div>

			<div class="commerce-form-field">
				<label for="account-address1">Address</label>
				<input id="account-address1" type="text" name="address1" autocomplete="address-line1" required />
			</div>
			<div class="commerce-form-field">
				<label for="account-address2">Apartment, suite, etc. (optional)</label>
				<input id="account-address2" type="text" name="address2" autocomplete="address-line2" />
			</div>

			<div class="commerce-form-row commerce-form-row--three">
				<div class="commerce-form-field">
					<label for="account-city">City</label>
					<input id="account-city" type="text" name="city" autocomplete="address-level2" required />
				</div>
				<div class="commerce-form-field">
					<label for="account-state">State</label>
					<input id="account-state" type="text" name="state" autocomplete="address-level1" required />
				</div>
				<div class="commerce-form-field">
					<label for="account-zip">Postal Code</label>
					<input id="account-zip" type="text" name="postalCode" autocomplete="postal-code" required />
				</div>
			</div>

			<div class="commerce-form-field">
				<label for="account-country">Country</label>
				<select id="account-country" name="country" autocomplete="country" required>
					<option value="">Select a country</option>
					<option value="US">United States</option>
					<option value="CA">Canada</option>
					<option value="GB">United Kingdom</option>
					<option value="AU">Australia</option>
				</select>
			</div>

			<div class="commerce-form-actions">
				<button type="submit" data-commerce-btn="primary">Save Address</button>
				<button type="button" data-commerce-cancel-address>Cancel</button>
			</div>
		</form>
	</section>

	<!-- Subscriptions -->
	<section data-commerce-panel="subscriptions" class="commerce-account-panel" hidden>
		<h2 class="commerce-section-title">Subscriptions</h2>
		<p data-commerce-subscriptions-empty class="commerce-empty-state" hidden>
			No active subscriptions.
		</p>
		<div data-commerce-subscriptions-list class="commerce-subscriptions-list"></div>
	</section>
</div>

<style>
	.commerce-account-nav {
		display: flex;
		border-bottom: 2px solid var(--commerce-border, #e5e7eb);
		margin-bottom: 1.5rem;
		gap: 0;
	}
	.commerce-account-tab {
		padding: 0.75rem 1.25rem;
		background: none;
		border: none;
		border-bottom: 2px solid transparent;
		margin-bottom: -2px;
		cursor: pointer;
		font-size: 0.9375rem;
		font-weight: 500;
		color: var(--commerce-text-muted, #6b7280);
		transition: color 0.15s, border-color 0.15s;
	}
	.commerce-account-tab--active,
	.commerce-account-tab[aria-selected="true"] {
		color: var(--commerce-primary, #2563eb);
		border-bottom-color: var(--commerce-primary, #2563eb);
		font-weight: 600;
	}

	.commerce-section-title {
		font-size: 1.25rem;
		font-weight: 700;
		color: var(--commerce-text, #1f2937);
		margin: 0 0 1rem;
	}
	.commerce-section-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-bottom: 1rem;
	}
	.commerce-section-header .commerce-section-title { margin-bottom: 0; }

	.commerce-empty-state,
	.commerce-loading-state {
		color: var(--commerce-text-muted, #6b7280);
		text-align: center;
		padding: 2.5rem 0;
		font-size: 0.9375rem;
	}

	.commerce-orders-list { display: flex; flex-direction: column; gap: 1rem; }
	.commerce-addresses-list {
		display: grid;
		gap: 1rem;
	}
	@media (min-width: 640px) {
		.commerce-addresses-list { grid-template-columns: repeat(2, 1fr); }
	}
	.commerce-subscriptions-list { display: flex; flex-direction: column; gap: 1rem; }

	.commerce-address-form {
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		padding: 1.5rem;
		margin-top: 1rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.commerce-form-title {
		font-size: 1rem;
		font-weight: 700;
		color: var(--commerce-text, #1f2937);
		margin: 0;
	}
	.commerce-form-row { display: grid; gap: 1rem; }
	.commerce-form-row--two { grid-template-columns: 1fr 1fr; }
	.commerce-form-row--three { grid-template-columns: 1fr 1fr 1fr; }
	@media (max-width: 480px) {
		.commerce-form-row--two,
		.commerce-form-row--three { grid-template-columns: 1fr; }
	}

	.commerce-form-field { display: flex; flex-direction: column; gap: 0.25rem; }
	.commerce-form-field label {
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-form-field input,
	.commerce-form-field select {
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		font-size: 0.9375rem;
		background: var(--commerce-bg, #ffffff);
	}

	.commerce-form-actions {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}
	.commerce-form-actions [data-commerce-cancel-address] {
		background: none;
		border: none;
		padding: 0;
		cursor: pointer;
		color: var(--commerce-text-muted, #6b7280);
		font-size: 0.9375rem;
	}
</style>
