---
interface Props {
	apiBase?: string;
	checkoutUrl?: string;
	continueShoppingUrl?: string;
}

const {
	apiBase = "/_emdash/api/plugins/commerce",
	checkoutUrl = "/checkout",
	continueShoppingUrl = "/products",
} = Astro.props;
---

<div data-commerce-cart-page data-api-base={apiBase}>
	<h1 class="commerce-page-title">Shopping Cart</h1>

	<div class="commerce-cart-layout">
		<div class="commerce-cart-main">
			<p data-commerce-cart-empty class="commerce-cart-empty" hidden>
				Your cart is empty.
				<a href={continueShoppingUrl}>Continue shopping</a>
			</p>

			<table data-commerce-cart-table class="commerce-cart-table" hidden>
				<thead>
					<tr>
						<th scope="col">Product</th>
						<th scope="col">Price</th>
						<th scope="col">Quantity</th>
						<th scope="col">Total</th>
						<th scope="col"><span class="sr-only">Remove</span></th>
					</tr>
				</thead>
				<tbody data-commerce-cart-items></tbody>
			</table>

			<div class="commerce-cart-actions">
				<a href={continueShoppingUrl} class="commerce-link">← Continue Shopping</a>
			</div>
		</div>

		<aside class="commerce-cart-summary">
			<h2 class="commerce-summary-title">Order Summary</h2>

			<form data-commerce-coupon-form class="commerce-coupon-form">
				<label for="commerce-coupon" class="commerce-label">Coupon Code</label>
				<div class="commerce-coupon-row">
					<input
						id="commerce-coupon"
						type="text"
						name="coupon"
						data-commerce-coupon-input
						placeholder="Enter coupon code"
					/>
					<button type="submit" data-commerce-btn="primary">Apply</button>
				</div>
				<p data-commerce-coupon-message class="commerce-coupon-message" hidden></p>
			</form>

			<div class="commerce-summary-totals">
				<div class="commerce-summary-row">
					<span>Subtotal</span>
					<span data-commerce-subtotal>—</span>
				</div>
				<div data-commerce-discount-row class="commerce-summary-row" hidden>
					<span>Discount</span>
					<span data-commerce-discount>—</span>
				</div>
				<div class="commerce-summary-row commerce-summary-row--total">
					<span>Total</span>
					<span data-commerce-total>—</span>
				</div>
			</div>

			<a href={checkoutUrl} data-commerce-btn="primary" data-commerce-checkout-link class="commerce-checkout-link">
				Proceed to Checkout
			</a>
		</aside>
	</div>
</div>

<style>
	.commerce-page-title {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--commerce-text, #1f2937);
		margin: 0 0 2rem;
	}

	.commerce-cart-layout {
		display: grid;
		gap: 2rem;
	}
	@media (min-width: 1024px) {
		.commerce-cart-layout { grid-template-columns: 1fr 22rem; align-items: start; }
	}

	.commerce-cart-empty {
		color: var(--commerce-text-muted, #6b7280);
		text-align: center;
		padding: 3rem 0;
	}
	.commerce-cart-empty a { color: var(--commerce-primary, #2563eb); }

	.commerce-cart-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9375rem;
	}
	.commerce-cart-table th,
	.commerce-cart-table td {
		padding: 0.875rem 0.75rem;
		text-align: left;
		border-bottom: 1px solid var(--commerce-border, #e5e7eb);
		color: var(--commerce-text, #1f2937);
	}
	.commerce-cart-table th {
		font-weight: 600;
		background: var(--commerce-bg-muted, #f9fafb);
	}

	.commerce-cart-actions {
		padding: 1rem 0;
	}
	.commerce-link {
		color: var(--commerce-primary, #2563eb);
		text-decoration: none;
		font-size: 0.9375rem;
	}

	.commerce-cart-summary {
		background: var(--commerce-bg-muted, #f9fafb);
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		padding: 1.5rem;
	}
	.commerce-summary-title {
		font-size: 1.125rem;
		font-weight: 700;
		margin: 0 0 1.25rem;
		color: var(--commerce-text, #1f2937);
	}

	.commerce-coupon-form { margin-bottom: 1.25rem; }
	.commerce-label {
		display: block;
		font-weight: 600;
		font-size: 0.875rem;
		margin-bottom: 0.375rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-coupon-row {
		display: flex;
		gap: 0.5rem;
	}
	.commerce-coupon-row input {
		flex: 1;
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		font-size: 0.875rem;
		background: var(--commerce-bg, #ffffff);
	}
	.commerce-coupon-message {
		font-size: 0.8125rem;
		margin-top: 0.375rem;
	}

	.commerce-summary-totals {
		display: flex;
		flex-direction: column;
		gap: 0.625rem;
		margin-bottom: 1.5rem;
	}
	.commerce-summary-row {
		display: flex;
		justify-content: space-between;
		font-size: 0.9375rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-summary-row--total {
		font-weight: 700;
		font-size: 1.0625rem;
		padding-top: 0.625rem;
		border-top: 1px solid var(--commerce-border, #e5e7eb);
	}

	.commerce-checkout-link {
		display: block;
		text-align: center;
		text-decoration: none;
		width: 100%;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border-width: 0;
	}
</style>
