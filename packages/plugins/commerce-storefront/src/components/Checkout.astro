---
interface Props {
	apiBase?: string;
	confirmationUrl?: string;
}

const {
	apiBase = "/_emdash/api/plugins/commerce",
	confirmationUrl = "/order-confirmation",
} = Astro.props;
---

<div data-commerce-checkout data-api-base={apiBase} data-confirmation-url={confirmationUrl}>
	<div class="commerce-checkout-steps" aria-label="Checkout steps">
		<div data-commerce-step="shipping" class="commerce-step commerce-step--active" aria-current="step">
			<span class="commerce-step__num">1</span>
			<span class="commerce-step__label">Shipping</span>
		</div>
		<div class="commerce-step-divider" aria-hidden="true"></div>
		<div data-commerce-step="payment" class="commerce-step">
			<span class="commerce-step__num">2</span>
			<span class="commerce-step__label">Payment</span>
		</div>
	</div>

	<div class="commerce-checkout-layout">
		<div class="commerce-checkout-main">
			<!-- Step 1: Shipping -->
			<section data-commerce-section="shipping" class="commerce-checkout-section">
				<h2 class="commerce-section-title">Shipping Information</h2>

				<form data-commerce-shipping-form class="commerce-form" novalidate>
					<div class="commerce-form-row commerce-form-row--two">
						<div class="commerce-form-field">
							<label for="checkout-first-name">First Name</label>
							<input
								id="checkout-first-name"
								type="text"
								name="firstName"
								autocomplete="given-name"
								required
							/>
						</div>
						<div class="commerce-form-field">
							<label for="checkout-last-name">Last Name</label>
							<input
								id="checkout-last-name"
								type="text"
								name="lastName"
								autocomplete="family-name"
								required
							/>
						</div>
					</div>

					<div class="commerce-form-field">
						<label for="checkout-email">Email</label>
						<input
							id="checkout-email"
							type="email"
							name="email"
							autocomplete="email"
							required
						/>
					</div>

					<div class="commerce-form-field">
						<label for="checkout-phone">Phone (optional)</label>
						<input
							id="checkout-phone"
							type="tel"
							name="phone"
							autocomplete="tel"
						/>
					</div>

					<div class="commerce-form-field">
						<label for="checkout-address1">Address</label>
						<input
							id="checkout-address1"
							type="text"
							name="address1"
							autocomplete="address-line1"
							required
						/>
					</div>

					<div class="commerce-form-field">
						<label for="checkout-address2">Apartment, suite, etc. (optional)</label>
						<input
							id="checkout-address2"
							type="text"
							name="address2"
							autocomplete="address-line2"
						/>
					</div>

					<div class="commerce-form-row commerce-form-row--three">
						<div class="commerce-form-field">
							<label for="checkout-city">City</label>
							<input
								id="checkout-city"
								type="text"
								name="city"
								autocomplete="address-level2"
								required
							/>
						</div>
						<div class="commerce-form-field">
							<label for="checkout-state">State / Province</label>
							<input
								id="checkout-state"
								type="text"
								name="state"
								autocomplete="address-level1"
								required
							/>
						</div>
						<div class="commerce-form-field">
							<label for="checkout-zip">Postal Code</label>
							<input
								id="checkout-zip"
								type="text"
								name="postalCode"
								autocomplete="postal-code"
								required
							/>
						</div>
					</div>

					<div class="commerce-form-field">
						<label for="checkout-country">Country</label>
						<select id="checkout-country" name="country" autocomplete="country" required>
							<option value="">Select a country</option>
							<option value="US">United States</option>
							<option value="CA">Canada</option>
							<option value="GB">United Kingdom</option>
							<option value="AU">Australia</option>
						</select>
					</div>

					<div data-commerce-shipping-methods class="commerce-shipping-methods" hidden>
						<h3 class="commerce-subsection-title">Shipping Method</h3>
						<div data-commerce-shipping-methods-list class="commerce-methods-list"></div>
					</div>

					<button type="submit" data-commerce-btn="primary" class="commerce-form-submit">
						Continue to Payment
					</button>
				</form>
			</section>

			<!-- Step 2: Payment -->
			<section data-commerce-section="payment" class="commerce-checkout-section" hidden>
				<h2 class="commerce-section-title">Payment</h2>
				<p data-commerce-shipping-summary class="commerce-shipping-summary"></p>
				<button type="button" data-commerce-edit-shipping class="commerce-link">Edit</button>

				<div data-commerce-payment-container class="commerce-payment-container">
					<!-- Payment provider mounts here (e.g. Stripe Elements) -->
				</div>

				<div class="commerce-form-field">
					<label for="checkout-notes">Order Notes (optional)</label>
					<textarea
						id="checkout-notes"
						name="customerNotes"
						rows="3"
						placeholder="Special instructions for your order"
					></textarea>
				</div>

				<p data-commerce-checkout-error class="commerce-form-error" hidden></p>

				<button
					type="button"
					data-commerce-btn="primary"
					data-commerce-place-order
					class="commerce-form-submit"
				>
					Place Order
				</button>
			</section>
		</div>

		<aside class="commerce-checkout-summary">
			<h2 class="commerce-summary-title">Order Summary</h2>
			<div data-commerce-order-items class="commerce-order-items"></div>
			<div class="commerce-summary-totals">
				<div class="commerce-summary-row">
					<span>Subtotal</span>
					<span data-commerce-subtotal>—</span>
				</div>
				<div data-commerce-shipping-row class="commerce-summary-row" hidden>
					<span>Shipping</span>
					<span data-commerce-shipping-cost>—</span>
				</div>
				<div data-commerce-discount-row class="commerce-summary-row" hidden>
					<span>Discount</span>
					<span data-commerce-discount>—</span>
				</div>
				<div class="commerce-summary-row commerce-summary-row--total">
					<span>Total</span>
					<span data-commerce-total>—</span>
				</div>
			</div>
		</aside>
	</div>
</div>

<style>
	.commerce-checkout-steps {
		display: flex;
		align-items: center;
		margin-bottom: 2rem;
	}
	.commerce-step {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--commerce-text-muted, #6b7280);
	}
	.commerce-step--active { color: var(--commerce-primary, #2563eb); }
	.commerce-step__num {
		width: 1.75rem;
		height: 1.75rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 0.8125rem;
		font-weight: 700;
		border: 2px solid currentColor;
	}
	.commerce-step--active .commerce-step__num {
		background: var(--commerce-primary, #2563eb);
		color: white;
		border-color: var(--commerce-primary, #2563eb);
	}
	.commerce-step__label { font-weight: 600; font-size: 0.9375rem; }
	.commerce-step-divider {
		flex: 1;
		height: 2px;
		background: var(--commerce-border, #e5e7eb);
		margin: 0 1rem;
	}

	.commerce-checkout-layout {
		display: grid;
		gap: 2rem;
	}
	@media (min-width: 1024px) {
		.commerce-checkout-layout { grid-template-columns: 1fr 22rem; align-items: start; }
	}

	.commerce-section-title {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 1.25rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-subsection-title {
		font-size: 1rem;
		font-weight: 600;
		margin: 1.25rem 0 0.75rem;
		color: var(--commerce-text, #1f2937);
	}

	.commerce-form { display: flex; flex-direction: column; gap: 1rem; }
	.commerce-form-row { display: grid; gap: 1rem; }
	.commerce-form-row--two { grid-template-columns: 1fr 1fr; }
	.commerce-form-row--three { grid-template-columns: 1fr 1fr 1fr; }
	@media (max-width: 480px) {
		.commerce-form-row--two,
		.commerce-form-row--three { grid-template-columns: 1fr; }
	}

	.commerce-form-field { display: flex; flex-direction: column; gap: 0.25rem; }
	.commerce-form-field label {
		font-weight: 600;
		font-size: 0.875rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-form-field input,
	.commerce-form-field select,
	.commerce-form-field textarea {
		padding: 0.5625rem 0.75rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		font-size: 0.9375rem;
		background: var(--commerce-bg, #ffffff);
		color: var(--commerce-text, #1f2937);
	}
	.commerce-form-field input:focus,
	.commerce-form-field select:focus,
	.commerce-form-field textarea:focus {
		outline: 2px solid var(--commerce-primary, #2563eb);
		outline-offset: 1px;
	}

	.commerce-shipping-methods { padding: 1rem 0 0; }
	.commerce-methods-list { display: flex; flex-direction: column; gap: 0.5rem; }

	.commerce-form-submit { margin-top: 0.5rem; }

	.commerce-shipping-summary {
		font-size: 0.9375rem;
		color: var(--commerce-text-muted, #6b7280);
		margin: 0 0 0.25rem;
	}
	.commerce-link {
		background: none;
		border: none;
		padding: 0;
		color: var(--commerce-primary, #2563eb);
		cursor: pointer;
		font-size: 0.875rem;
		text-decoration: underline;
		margin-bottom: 1.25rem;
		display: inline-block;
	}

	.commerce-payment-container {
		min-height: 5rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		padding: 1rem;
		margin-bottom: 1rem;
	}

	.commerce-form-error {
		color: #dc2626;
		font-size: 0.875rem;
		margin: 0;
	}

	.commerce-summary-title {
		font-size: 1.125rem;
		font-weight: 700;
		margin: 0 0 1rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-checkout-summary {
		background: var(--commerce-bg-muted, #f9fafb);
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		padding: 1.5rem;
	}
	.commerce-order-items { margin-bottom: 1rem; }
	.commerce-summary-totals { display: flex; flex-direction: column; gap: 0.5rem; }
	.commerce-summary-row {
		display: flex;
		justify-content: space-between;
		font-size: 0.9375rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-summary-row--total {
		font-weight: 700;
		padding-top: 0.625rem;
		border-top: 1px solid var(--commerce-border, #e5e7eb);
	}
</style>
