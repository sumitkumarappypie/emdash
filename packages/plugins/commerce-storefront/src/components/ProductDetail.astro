---
interface Props {
	apiBase?: string;
	slug?: string;
}

const { apiBase = "/_emdash/api/plugins/commerce", slug } = Astro.props;
---

<div data-commerce-product-detail data-api-base={apiBase} data-slug={slug}>
	<div data-commerce-gallery class="commerce-gallery">
		<div data-commerce-gallery-main class="commerce-gallery__main">
			<img data-commerce-gallery-image src="" alt="" />
		</div>
		<div data-commerce-gallery-thumbs class="commerce-gallery__thumbs"></div>
	</div>

	<div data-commerce-product-info class="commerce-product-info">
		<h1 data-commerce-product-title class="commerce-product-title"></h1>

		<div data-commerce-product-pricing class="commerce-product-pricing">
			<span data-commerce-price class="commerce-price"></span>
			<span data-commerce-price-compare class="commerce-price-compare" hidden></span>
		</div>

		<div data-commerce-product-description class="commerce-product-description"></div>

		<form data-commerce-add-to-cart-form>
			<div data-commerce-variants class="commerce-variants" hidden>
				<label for="commerce-variant-select">Variant</label>
				<select id="commerce-variant-select" data-commerce-variant-select name="variantId">
					<option value="">Select an option</option>
				</select>
			</div>

			<div class="commerce-quantity">
				<label for="commerce-quantity-input">Quantity</label>
				<div class="commerce-quantity__controls">
					<button type="button" data-commerce-qty-dec aria-label="Decrease quantity">−</button>
					<input
						id="commerce-quantity-input"
						type="number"
						name="quantity"
						value="1"
						min="1"
						data-commerce-quantity-input
					/>
					<button type="button" data-commerce-qty-inc aria-label="Increase quantity">+</button>
				</div>
			</div>

			<button type="submit" data-commerce-btn="primary" data-commerce-add-to-cart>
				Add to Cart
			</button>
		</form>
	</div>
</div>

<style>
	[data-commerce-product-detail] {
		display: grid;
		gap: var(--commerce-grid-gap, 1.5rem);
	}
	@media (min-width: 768px) {
		[data-commerce-product-detail] { grid-template-columns: 1fr 1fr; }
	}

	.commerce-gallery__main img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--commerce-radius, 0.5rem);
		border: 1px solid var(--commerce-border, #e5e7eb);
	}
	.commerce-gallery__thumbs {
		display: flex;
		gap: 0.5rem;
		margin-top: 0.5rem;
		flex-wrap: wrap;
	}
	.commerce-gallery__thumbs img {
		width: 4rem;
		height: 4rem;
		object-fit: cover;
		border-radius: calc(var(--commerce-radius, 0.5rem) / 2);
		border: 2px solid transparent;
		cursor: pointer;
	}
	.commerce-gallery__thumbs img[aria-current="true"] {
		border-color: var(--commerce-primary, #2563eb);
	}

	.commerce-product-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--commerce-text, #1f2937);
		margin: 0 0 0.5rem;
	}
	.commerce-product-pricing {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}
	.commerce-product-description {
		color: var(--commerce-text-muted, #6b7280);
		line-height: 1.6;
		margin-bottom: 1.5rem;
	}

	.commerce-variants {
		margin-bottom: 1rem;
	}
	.commerce-variants label,
	.commerce-quantity label {
		display: block;
		font-weight: 600;
		margin-bottom: 0.25rem;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-variants select {
		width: 100%;
		padding: 0.5rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
	}

	.commerce-quantity { margin-bottom: 1.5rem; }
	.commerce-quantity__controls {
		display: flex;
		align-items: center;
		gap: 0;
		width: fit-content;
	}
	.commerce-quantity__controls button {
		width: 2.25rem;
		height: 2.25rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		background: var(--commerce-bg-muted, #f9fafb);
		cursor: pointer;
		font-size: 1rem;
	}
	.commerce-quantity__controls button:first-child {
		border-radius: var(--commerce-radius, 0.5rem) 0 0 var(--commerce-radius, 0.5rem);
	}
	.commerce-quantity__controls button:last-child {
		border-radius: 0 var(--commerce-radius, 0.5rem) var(--commerce-radius, 0.5rem) 0;
	}
	.commerce-quantity__controls input {
		width: 3rem;
		height: 2.25rem;
		text-align: center;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-left: none;
		border-right: none;
	}
</style>
