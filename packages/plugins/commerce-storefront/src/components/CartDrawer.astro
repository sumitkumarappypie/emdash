---
interface Props {
	apiBase?: string;
	checkoutUrl?: string;
}

const {
	apiBase = "/_emdash/api/plugins/commerce",
	checkoutUrl = "/checkout",
} = Astro.props;
---

<div data-commerce-cart-drawer data-api-base={apiBase} aria-hidden="true">
	<div data-commerce-cart-overlay class="commerce-cart-overlay"></div>

	<aside data-commerce-cart-panel class="commerce-cart-panel" aria-label="Shopping cart">
		<header class="commerce-cart-header">
			<h2 class="commerce-cart-title">Your Cart</h2>
			<button type="button" data-commerce-cart-close aria-label="Close cart">
				<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
					<path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
				</svg>
			</button>
		</header>

		<div data-commerce-cart-items class="commerce-cart-items">
			<p data-commerce-cart-empty class="commerce-cart-empty">Your cart is empty.</p>
		</div>

		<footer class="commerce-cart-footer">
			<form data-commerce-coupon-form class="commerce-coupon-form">
				<input
					type="text"
					name="coupon"
					data-commerce-coupon-input
					placeholder="Coupon code"
					aria-label="Coupon code"
				/>
				<button type="submit" data-commerce-btn="primary">Apply</button>
			</form>
			<p data-commerce-coupon-message class="commerce-coupon-message" hidden></p>

			<div class="commerce-cart-totals">
				<div class="commerce-cart-subtotal">
					<span>Subtotal</span>
					<span data-commerce-subtotal>—</span>
				</div>
				<div data-commerce-discount-row class="commerce-cart-discount" hidden>
					<span>Discount</span>
					<span data-commerce-discount>—</span>
				</div>
				<div class="commerce-cart-total">
					<span>Total</span>
					<span data-commerce-total>—</span>
				</div>
			</div>

			<a href={checkoutUrl} data-commerce-btn="primary" data-commerce-checkout-link class="commerce-checkout-link">
				Proceed to Checkout
			</a>
		</footer>
	</aside>
</div>

<style>
	[data-commerce-cart-drawer] {
		position: fixed;
		inset: 0;
		z-index: 1000;
		pointer-events: none;
	}
	[data-commerce-cart-drawer][aria-hidden="false"] {
		pointer-events: auto;
	}

	.commerce-cart-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.4);
		opacity: 0;
		transition: opacity 0.3s;
	}
	[data-commerce-cart-drawer][aria-hidden="false"] .commerce-cart-overlay {
		opacity: 1;
	}

	.commerce-cart-panel {
		position: absolute;
		top: 0;
		right: 0;
		height: 100%;
		width: min(28rem, 100vw);
		background: var(--commerce-bg, #ffffff);
		box-shadow: -4px 0 16px rgba(0, 0, 0, 0.12);
		display: flex;
		flex-direction: column;
		transform: translateX(100%);
		transition: transform 0.3s ease;
	}
	[data-commerce-cart-drawer][aria-hidden="false"] .commerce-cart-panel {
		transform: translateX(0);
	}

	.commerce-cart-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 1.25rem 1.5rem;
		border-bottom: 1px solid var(--commerce-border, #e5e7eb);
	}
	.commerce-cart-title {
		font-size: 1.125rem;
		font-weight: 700;
		margin: 0;
		color: var(--commerce-text, #1f2937);
	}
	.commerce-cart-header button {
		background: none;
		border: none;
		cursor: pointer;
		color: var(--commerce-text-muted, #6b7280);
		padding: 0.25rem;
	}

	.commerce-cart-items {
		flex: 1;
		overflow-y: auto;
		padding: 1rem 1.5rem;
	}
	.commerce-cart-empty {
		color: var(--commerce-text-muted, #6b7280);
		text-align: center;
		padding: 2rem 0;
	}

	.commerce-cart-footer {
		padding: 1rem 1.5rem;
		border-top: 1px solid var(--commerce-border, #e5e7eb);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.commerce-coupon-form {
		display: flex;
		gap: 0.5rem;
	}
	.commerce-coupon-form input {
		flex: 1;
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--commerce-border, #e5e7eb);
		border-radius: var(--commerce-radius, 0.5rem);
		font-size: 0.875rem;
	}
	.commerce-coupon-message {
		font-size: 0.875rem;
		margin: 0;
	}

	.commerce-cart-totals {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		font-size: 0.9375rem;
	}
	.commerce-cart-subtotal,
	.commerce-cart-discount,
	.commerce-cart-total {
		display: flex;
		justify-content: space-between;
	}
	.commerce-cart-total {
		font-weight: 700;
		font-size: 1.0625rem;
		color: var(--commerce-text, #1f2937);
	}

	.commerce-checkout-link {
		display: block;
		text-align: center;
		text-decoration: none;
		width: 100%;
	}
</style>
